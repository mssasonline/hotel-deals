# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of this deployment. Used for:
#   • Auth redirect URLs (password reset, email confirmation)
#   • Review request email links (/review/[token])
#   • Partner welcome email links (/partner/dashboard)
#   • OG metadataBase in app/layout.tsx
# Must also be added to Supabase → Authentication → URL Configuration → Redirect URLs
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Project Settings → API → anon / public key (safe to expose to client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings → API → service_role (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron Job Secret ───────────────────────────────────────────────────────────
# Protects /api/cron/* from unauthorized calls.
# Vercel reads this automatically and sends it as: Authorization: Bearer <secret>
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Google Maps ───────────────────────────────────────────────────────────────
# console.cloud.google.com → Maps Embed API → Credentials
# Restrict the key to your production domain in the GCP console
GOOGLE_MAPS_API_KEY=

# ── Email Notifications (Resend) ─────────────────────────────────────────────
# Set to true to enable transactional emails (booking confirmations, review requests)
NOTIFICATIONS_ENABLED=false

# resend.com → API Keys
RESEND_API_KEY=

# Must be a verified sender in your Resend dashboard
RESEND_FROM_EMAIL=noreply@yourdomain.com
